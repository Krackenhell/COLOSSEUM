# Market data source: "mock" (default) or "chainlink"
MARKET_SOURCE=chainlink

# Avalanche C-Chain RPC endpoint (Alchemy)
CHAINLINK_RPC_URL=https://avax-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE

# Cache TTL for chainlink prices (seconds)
CHAINLINK_CACHE_TTL_SEC=10

# Max staleness before rejecting a Chainlink price (seconds)
CHAINLINK_MAX_STALENESS_SEC=3600

# Max oracle age for trading execution (seconds). If chainlink oracle is older,
# switches to live exchange price. Set low (e.g. 10) to test the switch.
TRADING_MAX_ORACLE_AGE_SEC=60

# STRICT CHAINLINK ONLY mode: set to 1 to disable ALL fallbacks.
# Trading is blocked entirely when chainlink oracle is stale/unavailable.
# No mock, no live exchange, no last-good price substitution.
CHAINLINK_STRICT_ONLY=0

# Server port
PORT=8787
